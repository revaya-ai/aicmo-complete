ANTHROPIC_API_KEY=    # Station 1 (Brain): Claude generation
ZERNIO_API_KEY=       # Station 3 (Mission): publishing
META_ACCESS_TOKEN=       # Station 4 (Ads): Meta ad campaigns
LINKEDIN_ACCESS_TOKEN=   # Station 4 (Ads): LinkedIn ad campaigns
NOTION_TOKEN=         # Optional: content calendar / ops sync
DATAFORSEO_LOGIN=     # Intelligence + AEO: DataForSEO SEO/AEO signals (pay-as-you-go, $50 min deposit)
DATAFORSEO_PASSWORD=  # Intelligence + AEO: paired with DATAFORSEO_LOGIN; both required to go live
GSC_ACCESS_TOKEN=     # Intelligence: Google Search Console, pre-obtained OAuth2 bearer token (paired with GSC_SITE_URL)
GSC_SITE_URL=         # Intelligence: GSC verified property, e.g. https://lumenskin.com/ (required with GSC_ACCESS_TOKEN)
APIFY_TOKEN=          # Intelligence: Apify competitor scrapes (paid compute units)

# Studio render: Placid builds the on-brand content templates (credential-gated, offline by default)
PLACID_API_TOKEN=
# Studio render: optional default Placid template uuid to composite against
PLACID_TEMPLATE_UUID=
# Studio render: Gemini (Nano Banana) image model, opt in with AICMO_RENDER=gemini (credential-gated, offline by default)
GEMINI_API_KEY=

# Backup: Backblaze B2 off-site backup of pipeline artifacts (credential-gated, offline by default)
BACKBLAZE_KEY_ID=
BACKBLAZE_APPLICATION_KEY=
BACKBLAZE_BUCKET=
